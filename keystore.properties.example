# Copy this file to `keystore.properties` (same folder, repo root) and fill in your values.
# `keystore.properties` and *.jks are gitignored — NEVER commit them or your passwords.
#
# When keystore.properties is absent, release builds fall back to the debug signature (installable
# for testing, but NOT publishable). With it present, `:app:assembleRelease` signs for the store.
#
# Create the keystore first (run from the repo root):
#   keytool -genkeypair -v -keystore keystore/easy-xtream-release.jks \
#       -alias easyxtream -keyalg RSA -keysize 2048 -validity 10000 -storetype PKCS12
# PKCS12 uses one password for both the store and the key, so set storePassword == keyPassword below.

# Path to the .jks, relative to the repo root.
storeFile=keystore/easy-xtream-release.jks
storePassword=CHANGE_ME
keyAlias=easyxtream
keyPassword=CHANGE_ME
